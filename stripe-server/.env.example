# Stripe — ne pas committer le fichier .env (ni les clés)
# Copier en .env et remplir les valeurs.

STRIPE_SECRET_KEY=sk_test_...
STRIPE_PRICE_ID=price_...
PORT=4242
DOMAIN=http://localhost:4242

# URL du site (landing) pour la page de retour après paiement (return_url)
# Dev : http://localhost:5173
# Prod uwiapp.com : https://www.uwiapp.com (ou https://uwiapp.com si canonical)
FRONTEND_URL=http://localhost:5173

# Origine autorisée pour CORS. En prod uwiapp.com autoriser www + non-www.
# Dev : * ou http://localhost:5173
# Prod : https://www.uwiapp.com,https://uwiapp.com
CORS_ORIGIN=*
