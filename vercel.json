{
  "version": 2,
  "buildCommand": "cd landing && npm ci && npm run build",
  "outputDirectory": "landing/dist",
  "installCommand": "cd landing && npm ci",
  "framework": null,
  "routes": [
    { "src": "/robots.txt", "dest": "/robots.txt" },
    { "src": "/sitemap.xml", "dest": "/sitemap.xml" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}